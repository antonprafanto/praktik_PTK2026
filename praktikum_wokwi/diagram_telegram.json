{
  "version": 1,
  "author": "Fapet UNMUL — IoT Peternakan + Telegram 2026 (OLED + WiFi)",
  "editor": "wokwi",
  "parts": [
    {
      "id": "esp",
      "type": "wokwi-esp32-devkit-v1",
      "top": 230,
      "left": 80,
      "attrs": {}
    },
    {
      "id": "dht1",
      "type": "wokwi-dht22",
      "top": 30,
      "left": 10,
      "attrs": { "temperature": "33", "humidity": "75" }
    },
    {
      "id": "oled",
      "type": "wokwi-ssd1306",
      "top": 20,
      "left": 200,
      "attrs": { "i2cAddress": "0x3c" }
    },
    {
      "id": "led_alarm",
      "type": "wokwi-led",
      "top": 200,
      "left": 530,
      "attrs": { "color": "red", "label": "ALARM!" }
    },
    {
      "id": "r1",
      "type": "wokwi-resistor",
      "top": 270,
      "left": 530,
      "attrs": { "value": "220" }
    }
  ],
  "connections": [
    ["esp:TX0",  "$serialMonitor:RX", "", []],
    ["esp:RX0",  "$serialMonitor:TX", "", []],

    ["dht1:VCC", "esp:3V3",    "red",   []],
    ["dht1:GND", "esp:GND.1", "black", []],
    ["dht1:SDA", "esp:D15",   "green", []],

    ["oled:VCC", "esp:3V3",   "red",    []],
    ["oled:GND", "esp:GND.1", "black",  []],
    ["oled:SDA", "esp:D21",   "blue",   []],
    ["oled:SCL", "esp:D22",   "yellow", []],

    ["led_alarm:A", "r1:1",      "red",   []],
    ["r1:2",        "esp:D2",    "orange",[]],
    ["led_alarm:C", "esp:GND.1", "black", []]
  ],
  "serialMonitor": {
    "display": "always",
    "newline": "lf"
  },
  "dependencies": {}
}
